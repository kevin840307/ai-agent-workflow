{
  "qwen": {
    "auth_type": "",
    "reuse_session": false,
    "max_retries": 2
  },
  "agents": {
    "default": "qwen",
    "providers": {
      "qwen": {
        "type": "qwen_cli"
      },
      "opencode": {
        "type": "opencode_cli",
        "bin": "opencode",
        "mode": "run",
