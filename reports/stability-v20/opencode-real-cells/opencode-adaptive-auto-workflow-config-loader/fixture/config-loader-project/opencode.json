      "R:/**": "deny",
      "S:/**": "deny",
      "T:/**": "deny",
      "U:/**": "deny",
      "V:/**": "deny",
      "W:/**": "deny",
      "X:/**": "deny",
      "Y:/**": "deny",
      "Z:/**": "deny",
      "A:\\**": "deny",
      "B:\\**": "deny",
