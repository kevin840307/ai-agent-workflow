      "D:\\**": "deny",
      "E:\\**": "deny",
      "F:\\**": "deny",
      "G:\\**": "deny",
      "H:\\**": "deny",
      "I:\\**": "deny",
      "J:\\**": "deny",
      "K:\\**": "deny",
      "L:\\**": "deny",
      "M:\\**": "deny",
      "N:\\**": "deny",
      "O:\\**": "deny",
      "P:\\**": "deny",
      "Q:\\**": "deny",
