    "external_directory": {
      "*": "allow"
    },
    "bash": {
      "*": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "dir*": "allow",
      "ls*": "allow",
      "type *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "findstr *": "allow"
    },
    "task": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "question": "allow",
    "todowrite": "allow",
    "lsp": "allow",
    "skill": "allow",
    "doom_loop": "deny"
